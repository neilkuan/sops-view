{
  "name": "sops-view",
  "displayName": "sops-view",
  "description": "The extension for view/edit encrypt file by sops.",
  "version": "0.0.8",
  "publisher": "sops-view",
  "author": {
    "name": "sops-view"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neilkuan/sops-view.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sops-view.openDecrypted",
        "title": "SOPS: 開啟解密檔案"
      },
      {
        "command": "sops-view.reload",
        "title": "SOPS: 重新載入解密檔案"
      },
      {
        "command": "sops-view.runCommand",
        "title": "SOPS: 執行自訂命令"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sops-view.runCommand",
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "group": "sops-view"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sops-view.openDecrypted",
        "key": "ctrl+shift+d",
        "mac": "ctrl+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "sops-view.runCommand",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "explorerViewletVisible && (resourceExtname == .yaml || resourceExtname == .yml)"
      }
    ],
    "configuration": {
      "title": "SOPS View",
      "properties": {
        "sopsView.filePatterns": {
          "type": "array",
          "default": [
            "*.encrypted.yaml",
            "*.encrypted.yml",
            "*.sops.yaml",
            "*.sops.yml",
            "secrets.yaml",
            "secrets.yml",
            "secret.yaml",
            "secret.yml",
            "secrets.*.yaml",
            "secrets.*.yml",
            "secret.*.yaml",
            "secret.*.yml",
            "*.enc.json",
            "*.enc.yml",
            "*.enc.yaml"
          ],
          "description": "檔案名稱模式列表，用於識別需要解密的 SOPS 加密檔案（支援 glob 模式）。如果檔案名稱不匹配，擴充功能會自動檢查檔案內容是否包含 SOPS 加密標記"
        },
        "sopsView.awsAccountProfileMapping": {
          "type": "object",
          "default": {},
          "description": "AWS Account ID 到 AWS Profile 名稱的映射。例如：{\"123456789012\": \"prod-profile\", \"987654321098\": \"dev-profile\"}"
        },
        "sopsView.sopsExecutablePath": {
          "type": "string",
          "default": "sops",
          "description": "SOPS 可執行檔的路徑。如果 sops 在 PATH 中，可以使用 \"sops\""
        },
        "sopsView.debug": {
          "type": "boolean",
          "default": false,
          "description": "啟用 debug 模式，會在 Output Channel 中顯示詳細的日誌訊息。可以在 Output 面板中選擇 \"SOPS View\" 查看日誌"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "vsce:package": "vsce package",
    "package:vsix": "node package-vsix.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/js-yaml": "^4.0.9",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
